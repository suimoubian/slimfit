  "recipes": [
    {
      "id": "r01",
      "name": "燕麦蓝莓早餐碗",
      "mealType": "breakfast",
      "ingredients": [
        { "id": "oats", "amount": 40, "unit": "g" },
        { "id": "milk", "amount": 200, "unit": "ml" },
        { "id": "blueberry", "amount": 50, "unit": "g" },
        { "id": "banana", "amount": 0.5, "unit": "根" }
      ],
      "steps": [
        "燕麦和牛奶放入小锅中，中火煮3-5分钟，期间搅拌防止粘锅。",
        "煮至燕麦变软、粥状浓稠后盛入碗中。",
        "蓝莓洗净，香蕉切片，铺在燕麦粥上即可。",
        "喜欢甜味可加少许蜂蜜（不计入热量）。"
      ],
      "rationale": "燕麦富含beta-葡聚糖可溶性膳食纤维，能延缓胃排空、提供持久饱腹感，同时稳定血糖。蓝莓提供花青素抗氧化，香蕉补充钾元素。脱脂牛奶提供优质蛋白和钙。整个早餐约350kcal，低GI设计适合减脂期。"
    },
